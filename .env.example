# ─────────────────────────────────────────────────────────────────────────────
# Asterixsty Affiliate Manager — Environment Variables
# Copy file ini ke .env dan isi nilainya
# Railway akan mengisi DATABASE_URL otomatis dari PostgreSQL plugin
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Railway PostgreSQL plugin mengisi ini secara otomatis
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/asterixsty"

# ── App URL ───────────────────────────────────────────────────────────────────
# URL publik aplikasi (dari Railway: Settings → Domains)
# Digunakan untuk: Google Form banner header, reminder engine, callback URLs
NEXT_PUBLIC_APP_URL="https://your-app.up.railway.app"
NEXT_PUBLIC_BASE_URL="https://your-app.up.railway.app"

# ── Encryption ────────────────────────────────────────────────────────────────
# Kunci enkripsi untuk Google OAuth tokens (AES-256-GCM)
# Generate: openssl rand -base64 32
ENCRYPTION_KEY="your-random-32-char-secret-key-here"

# ── Google Integration ────────────────────────────────────────────────────────
# Buat di: https://console.cloud.google.com/apis/credentials
# Jenis: OAuth 2.0 → Web Application
# Authorized redirect URIs: https://your-app.up.railway.app/api/google/callback
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="https://your-app.up.railway.app/api/google/callback"

# ── NextAuth / Auth.js ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
# Wajib untuk session JWT signing
AUTH_SECRET="your-nextauth-secret"

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Buat akun gratis di: https://resend.com
# API Key: Dashboard → API Keys → Create
# Jika tidak diset, undangan akan di-log ke console (no email sent)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Alamat pengirim (harus domain yang sudah diverifikasi di Resend)
# Format: "Nama Pengirim <noreply@yourdomain.com>"
RESEND_FROM_EMAIL="Asterixsty Affiliate <noreply@yourdomain.com>"

# ── Debug Permissions (opsional) ──────────────────────────────────────────────
# Set ke "true" untuk mengaktifkan floating 🔐 debug panel di development
# Jangan aktifkan di production
NEXT_PUBLIC_DEBUG_PERMISSIONS="false"

# ── Node Environment ──────────────────────────────────────────────────────────
NODE_ENV="production"
