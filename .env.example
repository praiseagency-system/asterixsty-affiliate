# ─────────────────────────────────────────────────────────────────────────────
# Asterixsty Affiliate Manager — Environment Variables
# Copy file ini ke .env dan isi nilainya
# Railway akan mengisi DATABASE_URL otomatis dari PostgreSQL plugin
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Railway PostgreSQL plugin mengisi ini secara otomatis
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/asterixsty"

# ── App URL ───────────────────────────────────────────────────────────────────
# Primary public URL aplikasi — gunakan custom domain jika sudah aktif
# Digunakan untuk: invite email links, Google callback, reminder engine
NEXT_PUBLIC_APP_URL="https://app.praiseagency.id"
NEXT_PUBLIC_BASE_URL="https://app.praiseagency.id"

# ── Auth URL ──────────────────────────────────────────────────────────────────
# Auth.js (NextAuth v5) menggunakan AUTH_URL untuk membangun callback URL
# Harus sama dengan NEXT_PUBLIC_APP_URL di production
# trustHost: true di src/auth.ts membuat ini opsional, tapi best practice untuk diset
AUTH_URL="https://app.praiseagency.id"

# ── Encryption ────────────────────────────────────────────────────────────────
# Kunci enkripsi untuk Google OAuth tokens (AES-256-GCM)
# Generate: openssl rand -base64 32
ENCRYPTION_KEY="your-random-32-char-secret-key-here"

# ── Google Sign-In (OAuth login) ──────────────────────────────────────────────
# Buat di: https://console.cloud.google.com/apis/credentials
# Jenis: OAuth 2.0 → Web Application
#
# Authorized JavaScript origins:
#   https://app.praiseagency.id
#
# Authorized redirect URIs (NextAuth Google Sign-In callback):
#   https://app.praiseagency.id/api/auth/callback/google
#
# PENTING: Tambahkan kedua domain di atas ke Google Cloud Console!
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Google Sheets / Drive Integration ─────────────────────────────────────────
# Redirect URI untuk fitur integrasi Google Sheets (bukan sign-in)
# Buat credentials terpisah atau tambah URI ini ke credentials yang sama
#
# Authorized redirect URIs (Google Sheets integration):
#   https://app.praiseagency.id/api/google/callback
GOOGLE_REDIRECT_URI="https://app.praiseagency.id/api/google/callback"

# ── NextAuth / Auth.js ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
# Wajib untuk session JWT signing
AUTH_SECRET="your-nextauth-secret"

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Buat akun gratis di: https://resend.com
# API Key: Dashboard → API Keys → Create
# Jika tidak diset, undangan akan di-log ke console (no email sent)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Alamat pengirim (harus domain yang sudah diverifikasi di Resend)
# Format: "invite@yourdomain.com"  OR  "Nama <invite@yourdomain.com>"
# JANGAN gunakan @gmail.com/@yahoo.com — harus custom domain
RESEND_FROM="invite@praiseagency.id"
# Alias lama (masih didukung, tapi RESEND_FROM lebih diutamakan)
# RESEND_FROM_EMAIL="Praise Agency <invite@praiseagency.id>"

# ── Debug Permissions (opsional) ──────────────────────────────────────────────
# Set ke "true" untuk mengaktifkan floating 🔐 debug panel di development
# Jangan aktifkan di production
NEXT_PUBLIC_DEBUG_PERMISSIONS="false"

# ── Node Environment ──────────────────────────────────────────────────────────
NODE_ENV="production"
